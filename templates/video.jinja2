{% extends "main.jinja2" %}
{% block content %}
    <h2>{{ video["title"] }}</h2>
    <hr>

    <!-- Video -->
    {% set URL = "/videos/%s/%s" % (video['uploader_id'], video['id']) %}
    <video class = "video-js" controls preload = "auto" poster = "{{ URL }}.webp" width = "800" data-setup = "{}">
        <source src = "{{ URL }}.webm" type = "video/webm">
        <track kind = "captions" src = "{{ URL }}.en.vtt" srclang = "en" label = "English" default>
    </video>

    <hr>
    <span>
        <a href = "/channel/{{ video['uploader_id'] }}">{{ video["uploader_id"] }}</a> ({{ "{:,}".format(channel["subscribers"]) }} subscribers) <br>
        {{ video["duration_string"] }} • {{ "{:,}".format(video["view_count"]) }} views • {{ "{:,}".format(video["like_count"]) }} likes • {{ video["timestamp"] | naturaltime }}
    </span>
    <hr>
    <pre style = "text-wrap: wrap;">{{ video["description"] }}</pre>

    <!-- VideoJS -->
    <link href = "https://vjs.zencdn.net/8.23.4/video-js.css" rel = "stylesheet" />
    <script src = "https://vjs.zencdn.net/8.23.4/video.min.js"></script>
{% endblock %}
