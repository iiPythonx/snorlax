{% extends "main.jinja2" %}
{% from "macros/paginate.jinja2" import paginate %}

{% block content %}
    {% include "macros/header.jinja2" %}
    <section>
        <h2>{{ channel["name"] }}</h2>
        <span style = "line-height: 2;">{{ "{:,}".format(channel["subscribers"]) }} subscribers</span>
    </section>
    <hr>
    {{ paginate("videos", type = "video", params = "channel_id=" ~ channel["id"]) }}
{% endblock %}
