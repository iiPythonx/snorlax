{% macro paginate(endpoint, type, params, limit) %}
    <div
        class = "flex column"
        data-api-type = "{{ type }}"
        data-api-endpoint = "{{ endpoint }}"
        data-api-params = "{{ params or '' }}"
        data-api-limit = "{{ limit or 8 }}"
    >
        <div class = "flex item-list"></div>
        <article class = "flex paginator">
            <span class = "api-time"></span>
            <div>
                <button class = "btn-back">&lt; Back</button>
                <span class = "current-page">Page 1 / 1</span>
                <button class = "btn-next">Next &gt;</button>
            </div>
        </article>
    </div>
{% endmacro %}
